{
  "name": "ngx-scrollspy",
  "version": "2.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --project=TestCases --host=0.0.0.0",
    "build": "ng build ngx-scrollspy --configuration=production",
    "build:testcases": "ng build TestCases --configuration=production",
    "build:development": "ng build ngx-scrollspy --watch",
    "test": "ng test ngx-scrollspy --watch=false --code-coverage",
    "test:ci": "ng test ngx-scrollspy --watch=false --code-coverage --no-progress --browsers=ChromeHeadless",
    "test:watch": "ng test ngx-scrollspy --watch",
    "lint": "ng lint",
    "publish": "cd dist/ngx-scrollspy && npm publish --access public",
    "version": "npm pkg set version=$npm_package_version --prefix library/ngx-scrollspy && git add library/ngx-scrollspy/package.json",
    "release:major": "changelog -M && git add CHANGELOG.md && git commit -m 'updated CHANGELOG.md' && npm version major && git push origin && git push origin --tags",
    "release:minor": "changelog -m && git add CHANGELOG.md && git commit -m 'updated CHANGELOG.md' && npm version minor && git push origin && git push origin --tags",
    "release:patch": "changelog -p && git add CHANGELOG.md && git commit -m 'updated CHANGELOG.md' && npm version patch && git push origin && git push origin --tags"
  },
  "license": "MIT",
  "private": false,
  "dependencies": {
    "@angular/animations": "~19.2.0",
    "@angular/common": "~19.2.0",
    "@angular/compiler": "~19.2.0",
    "@angular/core": "~19.2.0",
    "@angular/forms": "~19.2.0",
    "@angular/platform-browser": "~19.2.0",
    "@angular/platform-browser-dynamic": "~19.2.0",
    "@angular/router": "~19.2.0",
    "ngx-markdown": "^19.0.0",
    "prismjs": "^1.29.0",
    "rxjs": "~7.8.0",
    "stickyfilljs": "^2.1.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~19.2.0",
    "@angular/cli": "~19.2.0",
    "@angular/compiler-cli": "~19.2.0",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.0.0",
    "angular-eslint": "~19.2.0",
    "eslint": "^9.0.0",
    "generate-changelog": "^1.8.0",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "karma-junit-reporter": "^2.0.1",
    "ng-packagr": "^19.2.0",
    "raw-loader": "^4.0.2",
    "typescript": "~5.7.0",
    "typescript-eslint": "~8.26.0"
  }
}
