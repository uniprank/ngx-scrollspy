{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "downlevelIteration": true,
    "module": "es2022",
    "moduleResolution": "node",
    "importHelpers": true,
    "target": "es2022",
    "typeRoots": ["node_modules/@types"],
    "lib": ["es2022", "dom"],
    "paths": {
      "@uniprank/ngx-scrollspy": ["dist/ngx-scrollspy"],
      "@uniprank/ngx-scrollspy/*": ["dist/ngx-scrollspy/*"],
      "styles-test-cases": ["library/TestCases/src/styles"]
    },
    "useDefineForClassFields": false
  }
}
